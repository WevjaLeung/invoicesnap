# InvoiceSnap — Environment Configuration
# Copy this to .env and fill in your values

# AI Provider (at least one required for AI-powered extraction)
# Without AI, InvoiceSnap still works with rule-based extraction
OPENAI_API_KEY=sk-...
# Or use DeepSeek (cheaper, equally good for extraction):
# DEEPSEEK_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.deepseek.com
# AI_MODEL=deepseek-chat

# Stripe (for payments — $9/month Pro plan)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_ID=price_...

# Site URL (for Stripe redirect)
SITE_URL=http://localhost:8000
